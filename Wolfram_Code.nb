      "to", " ", "display", " ", "the", " ", "value"}], ",", 
     RowBox[{"even", " ", "without", " ", "the", " ", "line"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dataPairs", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", ",", 
         RowBox[{"meanCurveMSD", "[", 
          RowBox[{"[", "t", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "1", ",", 
         RowBox[{"Length", "[", "meanCurveMSD", "]"}]}], "}"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"logData", "=", 
     RowBox[{"Quiet", "[", 
