         RowBox[{"FreeQ", "[", 
          RowBox[{"#", ",", 
           RowBox[{"Indeterminate", "|", 
            RowBox[{"-", "Infinity"}]}]}], "]"}], "&"}]}], "]"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"lineModel", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"logData", ",", "x", ",", "x"}], "]"}]}], ";"}], "\n", 
